# Backend (Node/TS)
backend/node_modules/
backend/dist/
backend/.env
# leagueCache.ts's Standings/Stats/News cache - cheap to refetch from ESPN,
# legitimately fine to lose on any restart (unlike the durable store below).
backend/cache/*.json
# Durable game-record store (gameStore.ts) - local dev copy only. In
# production this lives on a persistent Render Disk (DATA_DIR env var),
# not in the repo; historicalWatchability.json stays tracked as the
# immutable seed the store can always be rebuilt from.
backend/data/games.db
backend/data/games.db-wal
backend/data/games.db-shm

# Android / Gradle
mobile/.gradle/
mobile/.kotlin/
mobile/build/
mobile/app/build/
mobile/local.properties
mobile/.idea/
mobile/*.iml
mobile/app/*.iml
mobile/captures/
mobile/.cxx/

# Release signing - the upload keystore is the app's signing identity;
# never belongs in version control.
mobile/keystore/
mobile/keystore.properties

# Built debug APK, copied here (outside mobile/app/build/) after each build
# specifically so it stays in the Drive-synced tree for phone sideloading
# even once mobile/app/build/ itself gets excluded from Drive sync - a 20MB
# binary has no business in git either way.
mobile/apk-releases/

# OS
.DS_Store
Thumbs.db
.claude/settings.local.json

# OneDrive sync staging (this project lives in a OneDrive-synced folder)
.tmp.driveupload/
